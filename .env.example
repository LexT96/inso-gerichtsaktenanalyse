ANTHROPIC_API_KEY=sk-ant-...           # Required — bei Langdock: Langdock-API-Key
ANTHROPIC_BASE_URL=                    # Optional — leer = direkte Anthropic API (siehe Beispiele unten)
JWT_SECRET=                            # Required — mindestens 32 Zeichen
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
DATABASE_PATH=./data/insolvenz.db
UPLOAD_MAX_SIZE_MB=50
RATE_LIMIT_EXTRACTIONS_PER_HOUR=10
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=                # Required — wird beim ersten Start gehasht
CORS_ORIGIN=http://localhost:3005   # Für Produktion: Frontend-URL setzen (z.B. https://app.example.com)
PORT=3004
LOG_LEVEL=info
EXTRACTION_MODEL=claude-sonnet-4-6          # Stage 2: Extraction — bei Langdock z.B. claude-sonnet-4-6-default
UTILITY_MODEL=claude-haiku-4-5-20251001     # Stage 1 + 3: Analyse & Verifikation
DOMAIN_NAME=insolvenz.example.com    # Domain für TLS-Zertifikat (Produktion)
ACME_EMAIL=admin@example.com         # E-Mail für Let's Encrypt
DATA_RETENTION_HOURS=72              # Stunden bis zur automatischen Datenlöschung
DB_ENCRYPTION_KEY=                   # Required — mindestens 32 Zeichen, verschlüsselt result_json in SQLite (AES-256-GCM)

# ─── Azure Document Intelligence (OCR für gescannte PDFs) ───
# Wenn gesetzt: gescannte PDFs werden automatisch per OCR verarbeitet
# Wenn leer: nur PDFs mit eingebettetem Text werden unterstützt
AZURE_DOC_INTEL_ENDPOINT=              # z.B. https://akten-ocr.cognitiveservices.azure.com/
AZURE_DOC_INTEL_KEY=                   # Azure Cognitive Services API Key

# ─── Microsoft Entra ID (Azure AD) SSO ───
# Wenn gesetzt: SSO aktiviert, lokale Passwort-Anmeldung deaktiviert
# Wenn leer: lokale Passwort-Anmeldung aktiv (Standard)
AZURE_TENANT_ID=                     # Azure Tenant ID (z.B. 12345678-abcd-...)
AZURE_CLIENT_ID=                     # Azure App Registration Client ID
VITE_AZURE_TENANT_ID=               # Gleiche Tenant ID (fuer Frontend)
VITE_AZURE_CLIENT_ID=               # Gleiche Client ID (fuer Frontend)

# ─── Anbieter-Konfiguration ───
#
# Direkte Anthropic API (Standard):
#   ANTHROPIC_API_KEY=sk-ant-...
#   ANTHROPIC_BASE_URL=              (leer lassen)
#   EXTRACTION_MODEL=claude-sonnet-4-6
#   UTILITY_MODEL=claude-haiku-4-5-20251001
#
# Langdock (EU-Hosting, DSGVO-konform):
#   ANTHROPIC_API_KEY=<langdock-api-key>
#   ANTHROPIC_BASE_URL=https://api.langdock.com/anthropic/eu
#   EXTRACTION_MODEL=claude-sonnet-4-6-default
#   UTILITY_MODEL=claude-haiku-4-5-20251001
#   → Modellnamen prüfen: GET https://api.langdock.com/anthropic/eu/v1/models
#
# Azure AI Model Foundry:
#   ANTHROPIC_API_KEY=<azure-api-key>
#   ANTHROPIC_BASE_URL=https://<resource>.services.ai.azure.com/anthropic
#   EXTRACTION_MODEL=claude-sonnet-4-6
#   UTILITY_MODEL=claude-haiku-4-5-20251001
