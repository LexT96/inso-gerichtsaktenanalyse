ANTHROPIC_API_KEY=sk-ant-...           # Required
JWT_SECRET=                            # Required — mindestens 32 Zeichen
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
DATABASE_PATH=./data/insolvenz.db
UPLOAD_MAX_SIZE_MB=50
RATE_LIMIT_EXTRACTIONS_PER_HOUR=10
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=                # Required — wird beim ersten Start gehasht
CORS_ORIGIN=http://localhost:3005   # Für Produktion: Frontend-URL setzen (z.B. https://app.example.com)
PORT=3004
LOG_LEVEL=info
EXTRACTION_MODEL=claude-sonnet-4-6          # Stage 2: Extraction (Sonnet für beste Qualität)
UTILITY_MODEL=claude-haiku-4-5-20251001     # Stage 1 + 3: Analyse & Verifikation (Haiku reicht)
